# Shopify — Dev Dashboard app credentials (client credentials grant)
# SHOPIFY_SHOP takes the bare store handle or the full *.myshopify.com domain.
SHOPIFY_SHOP=storekeeper-demo
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# LLM — OpenRouter
# OPENROUTER_MODEL is the OpenRouter model slug the classifier uses.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.5

# LangSmith observability. Tracing sends run content (ticket text, order
# data, drafted replies) to LangSmith — set LANGSMITH_TRACING=false to keep
# everything local.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=storekeeper
